# Shared online leaderboard + visit counter (Supabase).
# Copy this file to `.env.local` and fill in your project's values.
# Both are safe to expose in the client: writes are guarded by Row-Level Security
# (see supabase/schema.sql). If either is missing, the game falls back to
# per-device localStorage automatically.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
